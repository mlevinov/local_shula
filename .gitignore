# =============================================================================
#  SECTION 1: Environment & Secrets
#  NEVER commit secrets. Always ignore virtual environments and .env files.
# =============================================================================

# Environment variables - ignore all .env files except the safe example ones
.env
.env.*


# Virtual Environment
# These are machine-specific and can be rebuilt from requirements.txt.
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# =============================================================================
#  SECTION 2: Python & Dependencies
#  General Python ignores for bytecode, caches, and packaging artifacts.
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/


# =============================================================================
#  SECTION 3: Django Specific
#  Ignores for files generated by Django.
# =============================================================================

# Local database file
# The development database should not be in version control.
db.sqlite3
db.sqlite3-journal

# Log files
*.log
logs/

# User-uploaded files
# These should be stored externally (like S3) in production, not in git.
media/

# Collected static files
# This directory is generated by the `collectstatic` command. Your source
# static files (e.g., in `your_app/static/`) should be version-controlled.
# Replace `staticfiles/` with your `STATIC_ROOT` setting if different.
staticfiles/
static_root/
static/

# Translations
*.mo
*.pot


# =============================================================================
#  SECTION 4: IDE & Editor Configuration
#  Ignores for editor-specific settings, focusing on VS Code.
# =============================================================================

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/


# =============================================================================
#  SECTION 5: Operating System Specific Files
#  Generic ignores for macOS, Windows, and Linux system files.
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
.Trashes
._*
.Spotlight-V100

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.*.swp
.*.swo
.Trash-*

# LTI 1.3 Certificates
certs/
server_certs/

# =============================================================================
#  SECTION 6: Cloud Storage Related
# =============================================================================

gcp-credentials.json

# =============================================================================
#  SECTION 7: TailScale Related
# =============================================================================

tailscale_state/


# =============================================================================
#  SECTION 8: Miscellaneous
# =============================================================================
course_content.md


# =============================================================================
#  SECTION 9: Celery Beat persistent files
# =============================================================================
celerybeat-schedule*